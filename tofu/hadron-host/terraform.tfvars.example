# Copy to terraform.tfvars (gitignored) or set via environment:
#   export TF_VAR_HCLOUD_TOKEN=...          (or doppler run --)
#   export TF_VAR_CLOUDFLARE_API_TOKEN=...
#   export TF_VAR_CLOUDFLARE_ZONE_ID=...

server_name        = "beta"
domain             = "hadronmemory.com"
service_subdomains = ["srv"] # proxied records, e.g. srv.hadronmemory.com
server_type        = "ccx23"
location           = "hil"

